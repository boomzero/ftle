{
  "name": "ftle",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "predev": "npm run prepare:katex && npm run prepare:css && wrangler types",
    "pretest": "npm run prepare:katex && npm run prepare:css && wrangler types",
    "prepare:katex": "node scripts/prepare-katex-assets.mjs",
    "prepare:css": "node scripts/build-css.mjs",
    "dev": "wrangler dev",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "deploy": "wrangler deploy",
    "migrate:local": "wrangler d1 migrations apply DB --local",
    "migrate:remote": "wrangler d1 migrations apply DB --remote"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "jose": "^5.9.0",
    "katex": "^0.16.11",
    "marked": "^14.1.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.2",
    "@tailwindcss/cli": "^4.3.2",
    "@tailwindcss/typography": "^0.5.20",
    "@types/node": "^22.10.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.10",
    "wrangler": "^4.69.0"
  }
}
